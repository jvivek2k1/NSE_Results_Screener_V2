# ============================================
# Indian Earnings Intelligence - Backend Config
# ============================================
# Copy this file to ".env" and fill in values.

# Server port
PORT=3001

# OpenAI API key (optional).
# If omitted, the platform uses a deterministic local analysis engine.
OPENAI_API_KEY=

# OpenAI model to use
OPENAI_MODEL=gpt-4o-mini

# --- Azure OpenAI / AI Foundry (keyless, recommended) ---
# When both ENDPOINT and DEPLOYMENT are set, the platform uses Azure OpenAI
# with Entra ID auth (no API key). Sign in with `az login`; the identity needs
# the "Cognitive Services OpenAI User" role on the Foundry resource.
# ENDPOINT may be the base resource URL or a full v1 target URI.
AZURE_OPENAI_ENDPOINT=https://nse-results-screener-resource.services.ai.azure.com
AZURE_OPENAI_DEPLOYMENT=NSE_RESULTS_SCREENER_MODEL
AZURE_OPENAI_API_VERSION=preview

# When true (default), the AI engine downloads each filing's results document
# (the NSE attachment, usually a zipped PDF) and feeds the extracted text to
# the model for deeper segment / guidance / commentary analysis.
AI_READ_PDF=true
# Max characters of extracted PDF text sent to the model per filing.
AI_PDF_MAX_CHARS=12000

# Data source mode:
#   live  -> REAL NSE quarterly filings + real financials (default)
#   mock  -> generate realistic synthetic filings (offline demo only)
#   auto  -> try live, fall back to mock if NSE is unreachable
DATA_MODE=live

# How many new filings to process per scan (live mode)
SCAN_BATCH_SIZE=8

# Only seed/scan filings broadcast within this many days (0 = no age limit).
# Avoids spending AI tokens on stale quarterly filings.
FILING_MAX_AGE_DAYS=1

# How many synthetic filings to emit per scan (mock mode)
MOCK_BATCH_SIZE=3

# Cron schedule for the auto-refresh engine (default: every minute)
SCAN_CRON=* * * * *

# --- Email-on-open notification (optional) ---
# When EMAIL_USER and EMAIL_APP_PASSWORD are set, the backend sends a short
# summary email each time the app is opened (throttled). For Yahoo, generate an
# "App Password" (Account Security > App passwords) — your normal password will
# NOT work. Keep these in .env only (it is gitignored); never commit them.
EMAIL_HOST=smtp.mail.yahoo.com
EMAIL_PORT=465
EMAIL_USER=jvivek2k1@yahoo.com
# Secret — leave blank here; set the real app password only in your local .env.
EMAIL_APP_PASSWORD=
EMAIL_FROM=jvivek2k1@yahoo.com
EMAIL_TO=jvivek2k1@yahoo.com
# Minimum minutes between "opened" emails (avoids inbox flooding on reloads).
EMAIL_THROTTLE_MINUTES=10
