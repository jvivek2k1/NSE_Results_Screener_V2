{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "aiLocation": {
      "value": "${AZURE_AI_LOCATION=eastus2}"
    },
    "resourceGroupName": {
      "value": "${AZURE_RESOURCE_GROUP=RG_JB_NSE_RESULTS_SCREENER}"
    },
    "principalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    },
    "principalName": {
      "value": "${AZURE_PRINCIPAL_NAME}"
    },
    "principalType": {
      "value": "${AZURE_PRINCIPAL_TYPE=User}"
    },
    "sqlDatabaseName": {
      "value": "${SQL_DATABASE=JBDB}"
    },
    "aiDeploymentName": {
      "value": "${AZURE_OPENAI_DEPLOYMENT=NSE_RESULTS_SCREENER_MODEL}"
    },
    "aiApiVersion": {
      "value": "${AZURE_OPENAI_API_VERSION=preview}"
    },
    "emailEnabled": {
      "value": "${AZURE_EMAIL_ENABLED=false}"
    },
    "emailHost": {
      "value": "${EMAIL_HOST=smtp.mail.yahoo.com}"
    },
    "emailPort": {
      "value": "${EMAIL_PORT=465}"
    },
    "emailUser": {
      "value": "${EMAIL_USER=}"
    },
    "emailFrom": {
      "value": "${EMAIL_FROM=}"
    },
    "emailTo": {
      "value": "${EMAIL_TO=}"
    },
    "emailThrottleMinutes": {
      "value": "${EMAIL_THROTTLE_MINUTES=10}"
    },
    "resourceTokenOverride": {
      "value": "${RESOURCE_TOKEN=}"
    },
    "vmAdminUsername": {
      "value": "${VM_ADMIN_USERNAME=}"
    },
    "vmAdminPassword": {
      "value": "${VM_ADMIN_PASSWORD=}"
    },
    "vmAllowedSourceIp": {
      "value": "${VM_ALLOWED_SOURCE_IP=}"
    }
  }
}
